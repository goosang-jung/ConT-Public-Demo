# ConT Public Demo - Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env to Git!

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ============================================
# DEMO API CONFIGURATION
# ============================================
DEMO_API_PORT=4000
DEMO_API_HOST=localhost

# ============================================
# MOCK DATA
# ============================================
# All demo data is synthetic (not production)
DEMO_MODE=true
DEMO_DATA_SOURCE=synthetic
DEMO_SYNTHETIC_DATA_PATH=./data/synthetic

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
# SECURITY (Demo Only)
# ============================================
# This is a demo - no real authentication required
# For production, use proper OAuth/JWT
DEMO_AUTH_ENABLED=false
DEMO_AUTH_TOKEN=demo-token-for-local-testing-only

# ============================================
# EXTERNAL SERVICES (None for Demo)
# ============================================
# This demo uses mock APIs only
# No real external services are called
EXTERNAL_SOLVER_ENABLED=false
DATABASE_ENABLED=false

# ============================================
# DEVELOPMENT TOOLS
# ============================================
VITE_DEBUG=false
WEBPACK_DEV_SERVER=true

# ============================================
# DEMO FEATURES
# ============================================
ENABLE_HYBRID_BONDING_DEMO=true
ENABLE_THERMAL_PROCESS_DEMO=true
ENABLE_MPSTATE_INSPECTOR=true

# ============================================
# NOTES
# ============================================
# This .env is for LOCAL DEVELOPMENT ONLY
# All values are safe to commit in .env.example
# No real secrets are included
# Do NOT add actual API keys, passwords, or credentials
